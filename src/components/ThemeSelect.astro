---
/**
 * Custom theme toggle — cycles through dark → light → auto.
 * Replaces Starlight's default <Select>-based ThemeSelect with a compact icon button.
 */
---

<starlight-theme-select>
  <button
    type="button"
    aria-label={Astro.locals.t('themeSelect.accessibleLabel')}
    class="theme-toggle"
  >
    <svg class="icon icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"/>
      <line x1="12" y1="1" x2="12" y2="3"/>
      <line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/>
      <line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg class="icon icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
    <svg class="icon icon-auto" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
      <line x1="8" y1="21" x2="16" y2="21"/>
      <line x1="12" y1="17" x2="12" y2="21"/>
    </svg>
  </button>
</starlight-theme-select>

{/* Inlined to avoid FOUC. Uses global scope from ThemeProvider.astro */}
<script is:inline>
  StarlightThemeProvider.updatePickers();
</script>

<script>
  type Theme = 'auto' | 'dark' | 'light';

  const storageKey = 'starlight-theme';
  const cycle: Theme[] = ['dark', 'light', 'auto'];

  const parseTheme = (theme: unknown): Theme =>
    theme === 'auto' || theme === 'dark' || theme === 'light' ? theme : 'auto';

  const loadTheme = (): Theme =>
    parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey));

  function storeTheme(theme: Theme): void {
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem(storageKey, theme === 'light' || theme === 'dark' ? theme : '');
    }
  }

  const getPreferredColorScheme = (): Theme =>
    matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';

  function applyTheme(theme: Theme): void {
    const resolved = theme === 'auto' ? getPreferredColorScheme() : theme;
    document.documentElement.dataset.theme = resolved;
    // Update all toggle buttons
    document.querySelectorAll('starlight-theme-select').forEach((el) => {
      el.setAttribute('data-current-theme', theme);
    });
    storeTheme(theme);
  }

  matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
    if (loadTheme() === 'auto') applyTheme('auto');
  });

  class StarlightThemeSelect extends HTMLElement {
    constructor() {
      super();
      const current = loadTheme();
      applyTheme(current);
      this.setAttribute('data-current-theme', current);

      this.querySelector('button')?.addEventListener('click', () => {
        const now = (this.getAttribute('data-current-theme') || 'auto') as Theme;
        const idx = cycle.indexOf(now);
        const next = cycle[(idx + 1) % cycle.length]!;
        applyTheme(next);
      });
    }
  }
  customElements.define('starlight-theme-select', StarlightThemeSelect);
</script>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .theme-toggle:hover {
    color: var(--sl-color-white);
    border-color: var(--sl-color-accent);
    background: rgba(37, 99, 235, 0.08);
  }

  .icon { display: none; }

  /* Show correct icon based on current theme */
  [data-current-theme='dark'] .icon-moon { display: block; }
  [data-current-theme='light'] .icon-sun { display: block; }
  [data-current-theme='auto'] .icon-auto { display: block; }
</style>
