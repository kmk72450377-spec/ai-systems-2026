          "gpu_index"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true
      },
      "_meta": {
        "fastmcp": {
          "tags": []
        }
      }
    },
    {
      "name": "get_mig_devices",
      "description": "특정 GPU의 MIG 장치 정보 조회\n\nArgs:\n    user_id: 사용자 식별자 (권한 확인용)\n    gpu_index: GPU 인덱스 (0부터 시작)\n    \nReturns:\n    MIG 장치 목록 및 정보",
      "inputSchema": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string"
          },
          "gpu_index": {
            "type": "integer"
          }
        },
        "required": [
          "user_id",
