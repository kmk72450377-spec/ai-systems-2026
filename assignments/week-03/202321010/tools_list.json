{
  "tools": [
    {
      "name": "list_gpus",
      "description": "시스템의 모든 GPU 목록 조회\n\nArgs:\n    user_id: 사용자 식별자 (권한 확인용)\n\nReturns:\n    GPU 목록과 기본 정보",
      "inputSchema": {
        "type": "object",
        "properties": {
          "user_id": {
            "default": "student",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": true
      },
      "_meta": {
        "fastmcp": {
          "tags": []
        }
      }
    },
    {
      "name": "get_gpu_info",
      "description": "특정 GPU의 상세 정보 조회\n\nArgs:\n    user_id: 사용자 식별자 (권한 확인용)\n    gpu_index: GPU 인덱스 (0부터 시작)\n    \nReturns:\n    GPU 상세 정보",
      "inputSchema": {
        "type": "object",
